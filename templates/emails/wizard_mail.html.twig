<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0; padding:0; background-color:#f8fafc; font-family:sans-serif;">

<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f8fafc; padding:32px 0;">
    <tr>
        <td align="center">
            <table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px; width:100%; background-color:#ffffff; border-radius:16px; border:1px solid #e2e8f0; overflow:hidden;">
                <tr><td style="background-color:#a3c644; padding:6px 0;">&nbsp;</td></tr>
                <tr>
                    <td style="padding:32px 40px;">
                        <h1 style="margin:0 0 20px; font-size:22px; color:#0f172a;">{{ wizard.title }}</h1>

                        {% if introText %}
                            <p style="font-size:15px; color:#475569; line-height:1.7; white-space:pre-wrap;">{{ introText|raw }}</p>
                        {% endif %}

                        {% if showData and fields|length > 0 %}
                            <p style="margin:32px 0 16px; font-size:11px; font-weight:700; text-transform:uppercase; color:#64748b; letter-spacing:0.08em;">
                                {{ 'yiggle_form_wizard.email.summary_title'|trans({}, 'yiggle_form_wizard') }}
                            </p>

                            {% for field in fields %}
                                {% if field.value is iterable and field.value is not empty and field.value|first is iterable %}
                                    <div style="margin-bottom:12px; border:1px solid #e2e8f0; border-radius:10px; padding:14px 16px; background:#f8fafc;">
                                        <div style="font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; margin-bottom:10px; letter-spacing:0.05em;">
                                            {{ field.label }}
                                        </div>
                                        {% for row in field.value %}
                                            <div style="background:#fff; border:1px solid #cbd5e1; border-radius:6px; padding:12px; margin-bottom:8px;">
                                                {% for subField in row %}
                                                    <div style="margin-bottom:8px;">
                                                        <div style="font-size:10px; font-weight:700; color:#94a3b8; text-transform:uppercase; margin-bottom:2px;">
                                                            {{ subField.label }}
                                                        </div>
                                                        <div style="font-size:14px; color:#0f172a;">
                                                            {{ subField.value|default('-') }}
                                                        </div>
                                                    </div>
                                                {% endfor %}
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% else %}
                                    <div style="margin-bottom:12px; background:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; padding:14px 16px;">
                                        <div style="font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; margin-bottom:6px; letter-spacing:0.05em;">
                                            {{ field.label }}
                                        </div>
                                        <div style="font-size:15px; color:#0f172a; line-height:1.5; font-weight:500;">
                                            {% if field.value is empty %}
                                                <em style="color:#94a3b8;">-</em>
                                            {% else %}
                                                {{ field.value|nl2br }}
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <td style="padding:20px 40px; background-color:#f8fafc; border-top:1px solid #e2e8f0; text-align:center;">
                        <p style="font-size:12px; color:#94a3b8;">
                            &copy; {{ "now"|date("Y") }} {{ wizard.fromName|default('Yiggle') }}
                        </p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>

</body>
</html>
