{% use "form_div_layout.html.twig" %}
{% trans_default_domain 'yiggle_form_wizard' %}

{% block form_row %}
    {% if form.vars.compound %}
        {% for child in form %}
            {{ form_row(child) }}
        {% endfor %}

        {{ form_errors(form) }}
    {% else %}
        {% set col = form.vars.row_attr['data-yw-width']
            ?? form.vars.attr['data-yw-width']
            ?? 12
        %}

        {% set describedby = [] %}
        {% if form.vars.help %}
            {% set describedby = describedby|merge([form.vars.id ~ '_help']) %}
        {% endif %}
        {% if form.vars.errors|length > 0 %}
            {% for e in form.vars.errors %}
                {% set describedby = describedby|merge([form.vars.id ~ '_error' ~ loop.index]) %}
            {% endfor %}
        {% endif %}

        {% set widget_attr = {} %}
        {% if describedby|length > 0 %}
            {% set widget_attr = widget_attr|merge({'aria-describedby': describedby|join(' ')}) %}
        {% endif %}
        {% if form.vars.errors|length > 0 %}
            {% set widget_attr = widget_attr|merge({'aria-invalid': 'true'}) %}
        {% endif %}

        <div class="yw-field" style="--yw-col: {{ col }};">
            {{ form_label(form) }}

            <div class="yw-control">
                {{ form_widget(form, { attr: widget_attr }) }}
            </div>

            {{ form_errors(form) }}
            {{ form_help(form) }}
        </div>
    {% endif %}
{% endblock %}

{% block form_label %}
    {% if label is not same as(false) %}
        {% set label_attr = label_attr|merge({
            class: (label_attr.class|default('') ~ ' yw-label')|trim
        }) %}

        {% if compound and expanded is defined and expanded %}
            <legend{% with {attr: label_attr} %}{{ block('attributes') }}{% endwith %}>
                {{ label|trans(label_translation_parameters, translation_domain) }}

                {% if required %}
                    <span class="yw-required" aria-hidden="true">*</span>
                {% endif %}
            </legend>
        {% else %}
            {% if not compound %}
                {% set label_attr = label_attr|merge({ for: id }) %}
            {% endif %}

            <label{% with {attr: label_attr} %}{{ block('attributes') }}{% endwith %}>
                {{ label|trans(label_translation_parameters, translation_domain) }}

                {% if required %}
                    <span class="yw-required" aria-hidden="true">*</span>
                {% endif %}
            </label>
        {% endif %}
    {% endif %}
{% endblock %}

{% block form_widget_simple %}
    {% set attr = attr|merge({
        class: (attr.class|default('') ~ ' yw-input')|trim
    }) %}
    {{ parent() }}
{% endblock %}

{% block textarea_widget %}
    {% set attr = attr|merge({
        class: (attr.class|default('') ~ ' yw-input')|trim,
        rows: attr.rows|default(3)
    }) %}
    {{ parent() }}
{% endblock %}

{% block choice_widget_collapsed %}
    {% set attr = attr|merge({ class: (attr.class|default('') ~ ' yw-input')|trim }) %}
    {{ parent() }}
{% endblock %}

{% block wizard_repeatable_group_row %}
    {% trans_default_domain 'yiggle_form_wizard' %}
    {% set config = form.vars.fields_config ?? {} %}

    {% set col = form.vars.row_attr['data-yw-width']
        ?? form.vars.attr['data-yw-width']
        ?? 12
    %}

    {% set rowLabel = 'yiggle_form_wizard.wizard.row_label'|trans|default('Add row') %}
    {% set addLabel = config.addLabel|default('Add') %}
    {% set removeLabel = config.removeLabel|default('Delete') %}

    <div class="yw-field yw-repeatable-field" style="--yw-col: {{ col }};">
        {% if form.vars.label %}
            <div class="yw-label">
                {{ form.vars.label|trans({}, form.vars.translation_domain ?? 'yiggle_form_wizard') }}
            </div>
        {% endif %}

        {{ form_help(form) }}

        <div class="yw-control">
            <div
                class="yw-repeatable-group"
                data-controller="yw-repeatable"
                data-yw-repeatable-row-label-value="{{ rowLabel }}"
                data-yw-repeatable-remove-label-value="{{ removeLabel }}"
                data-yw-repeatable-target-name-value="{{ form.vars.full_name }}"
            >
                <div class="yw-repeatable-container" data-yw-repeatable-target="container">
                    {% for child in form %}
                        <div class="yw-repeatable-row" data-yw-repeatable-target="row">
                            <header class="yw-repeatable-row-head">
                                <div class="yw-repeatable-row-title" data-yw-repeatable-target="title">
                                    {{ rowLabel }} {{ loop.index }}
                                </div>

                                <div class="yw-repeatable-row-actions">
                                    <button
                                        type="button"
                                        class="yw-btn yw-btn-link yw-btn-remove"
                                        data-action="click->yw-repeatable#removeRow"
                                    >
                                        {{ removeLabel }}
                                    </button>
                                </div>
                            </header>

                            <div class="yw-field-grid" role="group">
                                {% for field in child %}
                                    {{ form_row(field) }}
                                {% endfor %}
                            </div>
                        </div>
                    {% endfor %}
                </div>

                <template data-yw-repeatable-target="prototype">
                    <div class="yw-repeatable-row" data-yw-repeatable-target="row">
                        <header class="yw-repeatable-row-head">
                            <div class="yw-repeatable-row-title" data-yw-repeatable-target="title">
                                {{ rowLabel }} __name__
                            </div>

                            <div class="yw-repeatable-row-actions">
                                <button
                                    type="button"
                                    class="yw-btn yw-btn-link yw-btn-remove"
                                    data-action="click->yw-repeatable#removeRow"
                                >
                                    {{ removeLabel }}
                                </button>
                            </div>
                        </header>

                        <div class="yw-field-grid" role="group">
                            {% for field in form.vars.prototype %}
                                {{ form_row(field) }}
                            {% endfor %}
                        </div>
                    </div>
                </template>

                <div class="yw-repeatable-actions">
                    <button
                        type="button"
                        class="yw-btn-add"
                        data-action="click->yw-repeatable#addRow"
                    >
                        {{ addLabel }}
                    </button>
                </div>
            </div>
        </div>

        {{ form_errors(form) }}
    </div>
{% endblock %}

{% block choice_row %}
    {% set col = form.vars.row_attr['data-yw-width'] ?? form.vars.attr['data-yw-width'] ?? 12 %}

    {% set describedby = [] %}
    {% if form.vars.help %}
        {% set describedby = describedby|merge([form.vars.id ~ '_help']) %}
    {% endif %}
    {% if form.vars.errors|length > 0 %}
        {% for e in form.vars.errors %}
            {% set describedby = describedby|merge([form.vars.id ~ '_error' ~ loop.index]) %}
        {% endfor %}
    {% endif %}

    {% if expanded %}
        <fieldset
            class="yw-field"
            style="--yw-col: {{ col }};"
            {% if describedby|length > 0 %}aria-describedby="{{ describedby|join(' ') }}"{% endif %}
            {% if required %}data-required-group="1"{% endif %}
        >
            {{ form_label(form) }}

            <div class="yw-control">
                {{ form_widget(form) }}
            </div>

            {{ form_errors(form) }}
            {{ form_help(form) }}
        </fieldset>
    {% else %}
        <div class="yw-field" style="--yw-col: {{ col }};">
            {{ form_label(form) }}

            <div class="yw-control">
                {{ form_widget(form) }}
            </div>

            {{ form_errors(form) }}
            {{ form_help(form) }}
        </div>
    {% endif %}
{% endblock %}

{% block choice_widget_expanded %}
    {% set container_attr = attr|merge({
        class: (attr.class|default('') ~ ' yw-selection-cards-container')|trim
    }) %}

    <div {% with { attr: container_attr } %}{{ block('attributes') }}{% endwith %}>
        {% for child in form %}
            {{ form_row(child) }}
        {% endfor %}
    </div>
{% endblock %}

{% block checkbox_row %}
    {% set col = form.vars.row_attr['data-yw-width'] ?? form.vars.attr['data-yw-width'] ?? 12 %}
    <div class="yw-field" style="--yw-col: {{ col }};">
        <div class="yw-control">
            <label class="yw-selection-card">
                {{ form_widget(form, { attr: { class: 'yw-selection-input' } }) }}
                <span class="yw-selection-label">
                    {{ form.vars.label|trans({}, translation_domain) }}
                </span>
            </label>
        </div>
        {{ form_errors(form) }}
        {{ form_help(form) }}
    </div>
{% endblock %}

{% block form_help %}
    {% if help %}
        <div id="{{ id ~ '_help' }}" class="yw-help">
            {{ help|trans({}, translation_domain) }}
        </div>
    {% endif %}
{% endblock %}

{% block form_errors %}
    {% if errors|length > 0 %}
        <div class="yw-errors" id="{{ id }}_errors">
            {% for error in errors %}
                <div id="{{ id ~ '_error' ~ loop.index }}" class="yw-error">
                    <span class="yw-error-icon">!</span>
                    {{ error.message }}
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}

